<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>io.github.kinsleykajiva</groupId>
        <artifactId>JavaRust-Webrtc</artifactId>
        <version>1.0-SNAPSHOT</version>
    </parent>

    <artifactId>library</artifactId>
    <packaging>jar</packaging>

    <dependencies>
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Native build pipeline: compile the Rust cdylib (cbindgen emits the C header),
                 then run jextract to generate FFM bindings from that header. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>build-rust-ffi</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>cargo</executable>
                            <workingDirectory>${ffi.crate.dir}</workingDirectory>
                            <arguments>
                                <argument>build</argument>
                                <argument>--release</argument>
                            </arguments>
                        </configuration>
                    </execution>
                    <execution>
                        <id>run-jextract</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>pwsh</executable>
                            <arguments>
                                <argument>-NoProfile</argument>
                                <argument>-Command</argument>
                                <argument>&quot;&amp; '${jextract.home}/bin/jextract.ps1'&quot;</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_init</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_free_string</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_config_create</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_config_add_ice_server</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_config_free</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_config_set_transport</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_peer_create</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_peer_close</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_create_offer</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_create_answer</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_set_local_description</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_set_remote_description</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_description_create</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_description_sdp</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_description_type</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_description_free</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_add_transceiver</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_add_ice_candidate</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_create_data_channel</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_data_channel_set_callbacks</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_data_channel_send_text</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_data_channel_send_bytes</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_supported_codecs</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_add_transceiver_from_kind</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_get_stats</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_track_remote_ssrcs</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_track_remote_codec</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_track_remote_kind</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_track_remote_rid</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_track_remote_write_rtcp</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_track_remote_set_callbacks</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_track_remote_id</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_track_remote_label</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_create_track_local</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_add_track</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_write_sample</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_get_senders</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_remove_track</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_sender_get_payload_type</argument>
                                <argument>--include-function</argument>
                                <argument>webrtc_ffi_sender_get_codec</argument>
                                <argument>-t</argument>
                                <argument>io.github.kinsleykajiva.webrtc.ffm</argument>
                                <argument>--output</argument>
                                <argument>${generated.sources.dir}</argument>
                                <argument>-I</argument>
                                <argument>${ffi.crate.dir}</argument>
                                <argument>${ffi.header}</argument>
                            </arguments>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Register the jextract output as a compile source root. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>add-generated-sources</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${generated.sources.dir}</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Embed the native library inside the jar under /native so it ships with the library. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>3.3.1</version>
                <executions>
                    <execution>
                        <id>copy-native-lib</id>
                        <phase>process-classes</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.build.outputDirectory}/native</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${ffi.crate.dir}/target/release</directory>
                                    <includes>
                                        <include>rust_webrtc_ffi.dll</include>
                                    </includes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Ensure the FFM native access flag is set for any in-module tests/runs. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.5.2</version>
                <configuration>
                    <argLine>--enable-native-access=ALL-UNNAMED</argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
